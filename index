<!DOCTYPE html>
<html>
<head>
  <title>CRUD Data Pasien</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<h2>Data Pasien</h2>

<form id="form">
  <input type="text" id="nama" placeholder="Nama" required>
  <input type="number" id="umur" placeholder="Umur" required>
  <input type="text" id="diagnosa" placeholder="Diagnosa" required>
  <button type="submit">Simpan</button>
</form>

<table border="1">
  <thead>
    <tr>
      <th>Nama</th>
      <th>Umur</th>
      <th>Diagnosa</th>
      <th>Aksi</th>
    </tr>
  </thead>
  <tbody id="dataPasien"></tbody>
</table>

<script src="script.js"></script>
</body>
</html>